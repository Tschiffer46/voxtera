{
  "name": "voxtera-server",
  "version": "1.0.0",
  "description": "Voxtera API server",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec 'node --import tsx/esm src/index.ts'",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node --import tsx/esm src/db/migrate.ts",
    "seed": "node --import tsx/esm src/db/seeds/seed.ts"
  },
  "dependencies": {
    "@types/express-rate-limit": "^5.1.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.0",
    "pg": "^8.13.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.9",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
